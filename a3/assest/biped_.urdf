<?xml version="1.0"?>
<robot name="biped_robot">

  <!-- Pelvis (Base Link) -->
  <link name="pelvis">
  <inertial>
    <mass value="0.6"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.01" iyy="0.01" izz="0.01"/>
  </inertial>
  <visual>
    <geometry><box size="0.14 0.14 0.02"/></geometry>
    <origin xyz="0 0 0"/>
    <material name="gray"><color rgba="0.5 0.45 0.4 1"/></material>
  </visual>
  <collision>
    <geometry><box size="0.12 0.02 0.12"/></geometry>
  </collision>
</link>


 

  <!-- LEFT LEG -->
  <link name="left_thigh">
    <inertial><mass value="0.3"/><origin xyz="0 0 -0.075"/><inertia ixx="0.003" iyy="0.003" izz="0.003"/></inertial>
    <visual><geometry><box size="0.035 0.035 0.15"/></geometry><origin xyz="0 0 -0.075"/></visual>
    <collision><geometry><box size="0.035 0.035 0.15"/></geometry></collision>
  </link>

  <joint name="left_hip" type="revolute">
    <parent link="pelvis"/>
    <child link="left_thigh"/>
    <origin xyz="0.04 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.87" effort="15" velocity="2"/>
  </joint>

  <link name="left_shin">
    <inertial><mass value="0.3"/><origin xyz="0 0 -0.075"/><inertia ixx="0.003" iyy="0.003" izz="0.003"/></inertial>
    <visual><geometry><box size="0.03 0.03 0.15"/></geometry><origin xyz="0 0 -0.075"/></visual>
    <collision><geometry><box size="0.03 0.03 0.15"/></geometry></collision>
  </link>

  <joint name="left_knee" type="revolute">
    <parent link="left_thigh"/>
    <child link="left_shin"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1" upper="0" effort="15" velocity="2"/>
  </joint>

  <link name="left_foot">
    <inertial><mass value="0.125"/><origin xyz="0 0 -0.01"/><inertia ixx="0.00125" iyy="0.00125" izz="0.00125"/></inertial>
    <visual><geometry><box size="0.055 0.075 0.02"/></geometry><origin xyz="0 0 0"/></visual>
    <collision><geometry><box size="0.06 0.08 0.025"/></geometry>

    </collision>
  </link>

  <joint name="left_ankle" type="revolute">
    <parent link="left_shin"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2" upper="0.78" effort="7.5" velocity="1"/>
  </joint>

  <!-- RIGHT LEG -->
  <link name="right_thigh">
    <inertial><mass value="0.3"/><origin xyz="0 0 -0.075"/><inertia ixx="0.003" iyy="0.003" izz="0.003"/></inertial>
    <visual><geometry><box size="0.035 0.035 0.15"/></geometry><origin xyz="0 0 -0.075"/></visual>
    <collision><geometry><box size="0.035 0.035 0.15"/></geometry></collision>
  </link>

  <joint name="right_hip" type="revolute">
    <parent link="pelvis"/>
    <child link="right_thigh"/>
    <origin xyz="-0.04 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0 " upper="0.87" effort="15" velocity="2"/>
  </joint>

  <link name="right_shin">
    <inertial><mass value="0.3"/><origin xyz="0 0 -0.075"/><inertia ixx="0.003" iyy="0.003" izz="0.003"/></inertial>
    <visual><geometry><box size="0.03 0.03 0.15"/></geometry><origin xyz="0 0 -0.075"/></visual>
    <collision><geometry><box size="0.03 0.03 0.15"/></geometry></collision>
  </link>

  <joint name="right_knee" type="revolute">
    <parent link="right_thigh"/>
    <child link="right_shin"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1" upper="0" effort="15" velocity="2"/>
  </joint>

  <link name="right_foot">
    <inertial><mass value="0.125"/><origin xyz="0 0 -0.01"/><inertia ixx="0.00125" iyy="0.00125" izz="0.00125"/></inertial>
    <visual><geometry><box size="0.055 0.075 0.02"/></geometry><origin xyz="0 0 0"/></visual>
    <collision><geometry><box size="0.06 0.08 0.025"/></geometry>
    </collision>
  </link>

  <joint name="right_ankle" type="revolute">
    <parent link="right_shin"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -0.15"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2" upper="0.78" effort="7.5" velocity="1"/>
  </joint>

</robot>
